{
  "name": "giromesa-saas",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS multi-tenant para gestao de bares, restaurantes e food service.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build --concurrency=1",
    "typecheck": "turbo typecheck --concurrency=1",
    "test": "turbo test --concurrency=1",
    "test:coverage": "turbo test:coverage --concurrency=1 && node scripts/aggregate-coverage.mjs",
    "test:integration": "node scripts/run-api-integration-tests.mjs",
    "test:e2e:preflight": "node scripts/e2e-preflight.mjs",
    "test:e2e:dev": "node scripts/run-playwright-dev.mjs",
    "test:e2e": "pnpm --filter @giromesa/web build && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "security:preflight": "node scripts/security-preflight.mjs",
    "lint": "biome check .",
    "lint:copy": "biome check .",
    "format": "biome check --write .",
    "db:generate": "pnpm --filter @giromesa/db db:generate",
    "db:migrate": "pnpm --filter @giromesa/db db:migrate",
    "demo:reset": "pnpm db:migrate && pnpm --filter @giromesa/db db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^3.2.6",
    "glob": "13.0.6",
    "turbo": "^2.5.0",
    "typescript": "5.8.3"
  }
}
