# Runtime
NODE_ENV=development
APP_NAME=GiroMesa
APP_URL=http://localhost:3002
API_URL=http://localhost:3333
NEXT_PUBLIC_API_URL=http://localhost:3333
PUBLIC_APP_URL=http://localhost:3002

# Database
DATABASE_URL=postgres://giromesa:giromesa@localhost:55432/giromesa
REDIS_URL=redis://localhost:6380

# Auth
SESSION_SECRET=replace-with-a-long-random-secret
PASSWORD_PEPPER=replace-with-a-long-random-pepper
MFA_ISSUER=GiroMesa
MFA_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-or-long-random-secret

# Google Sign-In
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3333/api/v1/auth/google/callback

# Platform owner placeholders
PLATFORM_SUPPORT_EMAIL=pendevtsp@example.com
PLATFORM_PRIVACY_EMAIL=privacy@example.com

# Asaas
ASAAS_ENV=sandbox
ASAAS_SANDBOX_URL=https://api-sandbox.asaas.com/v3
ASAAS_PRODUCTION_URL=https://api.asaas.com/v3
ASAAS_API_KEY=replace-with-sandbox-key
ASAAS_WEBHOOK_SECRET=replace-with-webhook-secret

# Meta WhatsApp Cloud API
META_WABA_ID=replace-with-waba-id
META_PHONE_NUMBER_ID=replace-with-phone-number-id
META_ACCESS_TOKEN=replace-with-token
META_WEBHOOK_VERIFY_TOKEN=replace-with-verify-token
META_APP_SECRET=replace-with-app-secret

# iFood webhook: keep disabled until a signed production contract is implemented.
IFOOD_WEBHOOK_MODE=disabled

# Dose Club
CLUB_WHISKY_API_BASE_URL=https://club.example.com
CLUB_WHISKY_API_KEY=replace-with-club-api-key
CLUB_WHISKY_WEBHOOK_SECRET=replace-with-club-webhook-secret

# Local printer connector
GIROMESA_BRANCH_ID=replace-with-branch-id
GIROMESA_CONNECTOR_TOKEN=replace-with-generated-connector-token
CONNECTOR_DRY_RUN=true
CONNECTOR_POLL_MS=2500
# Optional fallback only. Prefer printer host/port from printer_devices.
CONNECTOR_PRINTER_HOST=192.168.15.41
CONNECTOR_PRINTER_PORT=9100

# Fiscal provider
FISCAL_PROVIDER=mock
FISCAL_API_BASE_URL=https://sandbox.example.com
FISCAL_API_KEY=replace-with-provider-key
FISCAL_CERTIFICATE_A1=replace-with-secure-secret-reference
FISCAL_CSC_TOKEN=replace-with-secure-secret-reference
FOCUS_NFE_TOKEN=replace-with-focus-nfe-token
FOCUS_NFE_HOMOLOGATION_URL=https://homologacao.focusnfe.com.br
FOCUS_NFE_PRODUCTION_URL=https://api.focusnfe.com.br

# Legacy fiscal provider placeholders
NUVEM_FISCAL_CLIENT_ID=replace-with-nuvem-fiscal-client-id
NUVEM_FISCAL_CLIENT_SECRET=replace-with-nuvem-fiscal-client-secret
NUVEM_FISCAL_AUTH_URL=https://auth.nuvemfiscal.com.br/oauth/token
NUVEM_FISCAL_SANDBOX_URL=https://api.sandbox.nuvemfiscal.com.br
NUVEM_FISCAL_PRODUCTION_URL=https://api.nuvemfiscal.com.br
NUVEM_FISCAL_SCOPE=empresa nfce nfe nfse

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-user
SMTP_PASSWORD=replace-with-password
EMAIL_FROM=no-reply@example.com

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=replace-with-account-id
CLOUDFLARE_ZONE_ID=replace-with-zone-id
CLOUDFLARE_API_TOKEN=replace-with-token
TURNSTILE_SITE_KEY=replace-with-site-key
TURNSTILE_SECRET_KEY=replace-with-secret-key
R2_ACCOUNT_ID=replace-with-account-id
R2_ACCESS_KEY_ID=replace-with-access-key
R2_SECRET_ACCESS_KEY=replace-with-secret
R2_BUCKET=giromesa-assets

# Observability
SENTRY_DSN=
LOG_LEVEL=info
