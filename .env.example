# Runtime
NODE_ENV=development
APP_NAME=GiroMesa
APP_URL=http://localhost:3000
API_URL=http://localhost:3333
PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://giromesa:giromesa@localhost:55432/giromesa
REDIS_URL=redis://localhost:6380

# Auth
SESSION_SECRET=replace-with-a-long-random-secret
PASSWORD_PEPPER=replace-with-a-long-random-pepper
MFA_ISSUER=GiroMesa

# Platform owner placeholders
PLATFORM_SUPPORT_EMAIL=pendevtsp@example.com
PLATFORM_PRIVACY_EMAIL=privacy@example.com

# Asaas
ASAAS_ENV=sandbox
ASAAS_API_KEY=replace-with-sandbox-key
ASAAS_WEBHOOK_SECRET=replace-with-webhook-secret

# Meta WhatsApp Cloud API
META_WABA_ID=replace-with-waba-id
META_PHONE_NUMBER_ID=replace-with-phone-number-id
META_ACCESS_TOKEN=replace-with-token
META_WEBHOOK_VERIFY_TOKEN=replace-with-verify-token
META_APP_SECRET=replace-with-app-secret

# Fiscal provider
FISCAL_PROVIDER=mock
FISCAL_API_BASE_URL=https://sandbox.example.com
FISCAL_API_KEY=replace-with-provider-key

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-user
SMTP_PASSWORD=replace-with-password
EMAIL_FROM=no-reply@example.com

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=replace-with-account-id
CLOUDFLARE_ZONE_ID=replace-with-zone-id
CLOUDFLARE_API_TOKEN=replace-with-token
TURNSTILE_SITE_KEY=replace-with-site-key
TURNSTILE_SECRET_KEY=replace-with-secret-key
R2_ACCOUNT_ID=replace-with-account-id
R2_ACCESS_KEY_ID=replace-with-access-key
R2_SECRET_ACCESS_KEY=replace-with-secret
R2_BUCKET=giromesa-assets

# Observability
SENTRY_DSN=
LOG_LEVEL=info
