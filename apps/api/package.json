{
  "name": "@giromesa/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format esm --platform node --target node22 --sourcemap --out-dir dist",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --pool=threads --maxWorkers=1 --minWorkers=1",
    "test:coverage": "vitest run --passWithNoTests --pool=threads --maxWorkers=1 --minWorkers=1 --coverage --coverage.reporter=json-summary --coverage.reporter=lcov --coverage.reporter=text"
  },
  "dependencies": {
    "@giromesa/config": "workspace:*",
    "@giromesa/db": "workspace:*",
    "@giromesa/domain": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.0",
    "@types/qrcode": "^1.5.6",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "5.8.3",
    "vitest": "^3.0.0"
  }
}
