{
  "name": "@giromesa/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node22 --sourcemap --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --pool=threads --maxWorkers=1 --minWorkers=1",
    "test:coverage": "vitest run --passWithNoTests --pool=threads --maxWorkers=1 --minWorkers=1 --coverage --coverage.reporter=json-summary --coverage.reporter=lcov --coverage.reporter=text"
  },
  "dependencies": {
    "@giromesa/config": "workspace:*",
    "@giromesa/db": "workspace:*",
    "bullmq": "^5.0.0",
    "drizzle-orm": "^0.44.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "5.8.3",
    "vitest": "^3.0.0"
  }
}
