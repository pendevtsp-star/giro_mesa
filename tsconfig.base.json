{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@giromesa/config": ["packages/config/src/index.ts"],
      "@giromesa/db": ["packages/db/src/index.ts"],
      "@giromesa/domain": ["packages/domain/src/index.ts"],
      "@giromesa/ui": ["packages/ui/src/index.tsx"]
    }
  }
}
