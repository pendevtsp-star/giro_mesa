{
  "name": "@giromesa/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --pool=threads --maxWorkers=1 --minWorkers=1",
    "db:generate": "drizzle-kit generate",
    "db:check-applied": "node scripts/check-migrations-applied.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts",
    "db:reset-demo": "pnpm db:seed"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.44.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "typescript": "5.8.3",
    "vitest": "^3.0.0"
  }
}
